{
  "name": "pcb-preview",
  "version": "0.4.0",
  "description": "Multi-layer Gerber PCB preview and plotter toolchain",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Shivam Bajaj",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.antigravity.pcbpreview",
    "productName": "Antigravity PCB Preview",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/afterPack.js",
    "extraResources": [
      {
        "from": "backend-dist/pcb-preview-server",
        "to": "pcb-preview-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "nsis",
      "sign": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
